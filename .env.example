# Master encryption key for AES-256-GCM token encryption.
# Must be exactly 32 bytes or a 64-character hex string.
# You can generate one using: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional: SQLite Database URL (defaults to sqlite://data/cloudflare.db?mode=rwc if omitted)
# DATABASE_URL="sqlite://data/cloudflare.db?mode=rwc"

# Optional: HTTP Server Port (defaults to 8080 if omitted)
# PORT=8080

# Optional: Logging level
# RUST_LOG=info,cloudflare_dashboard_backend=debug
